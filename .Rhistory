chain1[2] <- NA
}
}
else{
chain2[1] <- chain1[1]
chain2[2] <- chain1[2]
chain1[1] <- 18
chain1[2] <- 1
total_c <- chain1[1] + chain2[1]
total_db <- chain1[2] + chain2[2]
}
}
table <- data.frame(
`Name` = name_2,
